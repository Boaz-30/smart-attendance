# ============================================================================
# SmartAttend Environment Configuration
# ============================================================================
# Copy this file to .env and update the values for your environment
# DO NOT commit .env file to version control - it contains sensitive secrets
# ============================================================================

# ============================================================================
# 1. NODE ENVIRONMENT
# ============================================================================
# development - for local development with hot reload
# production - for production builds and deployment
NODE_ENV=development

# ============================================================================
# 2. SERVER CONFIGURATION
# ============================================================================
# PORT on which the server will run
# Tip: If port 8080 is already in use, change this value and restart the server
PORT=8080

# ============================================================================
# 3. AUTHENTICATION & SECURITY
# ============================================================================
# JWT_SECRET - Secret key for signing JWT tokens
# IMPORTANT: In production, use a strong, random, unique key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DO NOT use the example value in production
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================================================
# 4. DATABASE CONFIGURATION (OPTIONAL)
# ============================================================================
# DATABASE_URL - PostgreSQL connection string
# Leave empty to run in demo mode with in-memory data (no database required)
# Format: postgresql://user:password@host:port/database
# Example: postgresql://postgres.abc123:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Demo Mode: Leave empty or comment out to use in-memory storage
DATABASE_URL=

# ============================================================================
# 5. API CONFIGURATION
# ============================================================================
# BASE_URL - The URL where the server is running (used for API generation)
# Used internally for API route generation and CORS configuration
BASE_URL=http://localhost:8080

# FRONTEND_URL - The URL of the frontend application
# IMPORTANT: Only required in production to enable proper CORS
# In development, CORS accepts all origins (*)
# Example: https://yourdomain.com
FRONTEND_URL=http://localhost:8080

# ============================================================================
# 6. BUILDER.IO INTEGRATION (OPTIONAL)
# ============================================================================
# VITE_PUBLIC_BUILDER_KEY - Public Builder.io API key for visual development
# Optional: Only needed if using Builder.io for design/development
# Leave empty if not using Builder.io
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__

# ============================================================================
# 7. APPLICATION MESSAGES
# ============================================================================
# PING_MESSAGE - Message returned by the /api/ping endpoint (for testing)
PING_MESSAGE=pong

# ============================================================================
# SUMMARY OF ENVIRONMENT MODES
# ============================================================================
# 
# DEVELOPMENT MODE (default):
#   - NODE_ENV=development
#   - DATABASE_URL= (empty for in-memory demo)
#   - PORT=8080
#   - CORS allows all origins (*)
#   - Hot reload enabled
#
# PRODUCTION MODE:
#   - NODE_ENV=production
#   - DATABASE_URL=postgresql://... (PostgreSQL connection)
#   - PORT=8080 (or your production port)
#   - CORS restricted to FRONTEND_URL
#   - JWT_SECRET=strong-random-key
#
# DEMO MODE (development without database):
#   - NODE_ENV=development
#   - DATABASE_URL= (empty)
#   - PORT=8080
#   - Uses in-memory data (lost on restart)
#   - Perfect for testing and exploration
#
# ============================================================================
